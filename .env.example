# Polymarket US API credentials.
# Generate an API key at https://polymarket.us/developer
# Copy this file to .env and fill in your values. NEVER commit .env.
#
# The Key ID is the public identifier for your API key.
POLYMARKET_KEY_ID=

# The Secret Key is your Ed25519 private signing key, shown only once at
# creation. Provide it base64-encoded (the format Polymarket displays).
# A 32-byte seed or a 64-byte expanded key are both accepted.
POLYMARKET_SECRET_KEY=

# Optional: override API hosts (defaults match docs.polymarket.us).
# POLYML_REST_BASE_URL=https://api.polymarket.us/v1
# POLYML_GATEWAY_BASE_URL=https://gateway.polymarket.us/v1
# POLYML_WS_PRIVATE_URL=wss://api.polymarket.us/v1/ws/private
# POLYML_WS_MARKETS_URL=wss://api.polymarket.us/v1/ws/markets

# Optional: path to the SQLite database (default: data/polyml.db)
# POLYML_DB_PATH=data/polyml.db
